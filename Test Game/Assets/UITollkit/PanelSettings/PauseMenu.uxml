<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UITollkit/PanelSettings/PauseMenu.uss?fileID=7433441132597879392&amp;guid=f78f2b478bae97b4bb22711e4664fa6d&amp;type=3#PauseMenu"/>
    <ui:VisualElement class="pause-overlay" style="flex-grow: 1;">
        <ui:VisualElement name="pause-bg" class="pause-bg" style="flex-grow: 1;">
            <ui:VisualElement name="pause-container" class="pause-container" style="flex-grow: 1; top: auto; justify-content: center; align-self: center; align-content: center; width: 372px; position: relative;">
                <ui:VisualElement style="flex-grow: 1; flex-wrap: wrap; top: 40%; position: absolute;">
                    <ui:Button text="Continue" name="continue-btn" style="height: 27px; width: 114px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; background-color: rgba(0, 0, 0, 0); color: rgb(255, 255, 255); font-size: 28px; border-left-color: rgba(0, 0, 0, 0); border-right-color: rgba(0, 0, 0, 0); border-top-color: rgba(0, 0, 0, 0); border-bottom-color: rgba(0, 0, 0, 0); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; top: auto; align-items: center; justify-content: center; align-self: center; align-content: center;"/>
                    <ui:Button text="Options" name="options-btn" style="height: 24px; width: 150px; font-size: 28px; color: rgb(255, 255, 255); background-color: rgba(0, 0, 0, 0); border-left-color: rgba(0, 0, 0, 0); border-right-color: rgba(0, 0, 0, 0); border-top-color: rgba(0, 0, 0, 0); border-bottom-color: rgba(0, 0, 0, 0); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; margin-top: 40px; margin-right: 0; margin-bottom: 40px; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                    <ui:Button text="Exit" name="exit-btn" style="height: 28px; width: 47px; background-color: rgba(0, 0, 0, 0); font-size: 28px; color: rgb(255, 255, 255); margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; border-left-color: rgba(0, 0, 0, 0); border-right-color: rgba(0, 0, 0, 0); border-top-color: rgba(0, 0, 0, 0); border-bottom-color: rgba(0, 0, 0, 0); align-items: center; justify-content: center; align-self: center; align-content: center;"/>
                    <ui:VisualElement name="options-panel" style="flex-grow: 1; position: absolute; height: 117px; width: 150px;">
                        <ui:Button text="Back" style="align-items: center; align-self: center; justify-content: center; align-content: center; font-size: 28px; color: rgb(255, 255, 255); background-color: rgba(0, 0, 0, 0); border-left-color: rgba(0, 0, 0, 0); border-right-color: rgba(0, 0, 0, 0); border-top-color: rgba(0, 0, 0, 0); border-bottom-color: rgba(0, 0, 0, 0); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0;"/>
                        <ui:Label text="Volume" style="-unity-background-image-tint-color: rgba(0, 0, 0, 0); color: rgb(255, 255, 255); -unity-text-align: upper-center; font-size: 20px;"/>
                        <ui:Slider label="" value="50" high-value="100" style="background-image: url(&quot;project://database/Assets/Futuridium_Assets/Menu/bar_2.png?fileID=2800000&amp;guid=f83ac058f608331418b2e1bcaee8dcff&amp;type=3#bar_2&quot;);"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
    <ui:Button text="||" name="pause-toggle-btn" class="corner-btn"/>
</ui:UXML>
